# --- Core ---
N8N_PORT=5678
TZ=Africa/Lagos
GENERIC_TIMEZONE=Africa/Lagos

# --- Security (recommended even for lab) ---
# Create a long random string (32+ chars)
N8N_ENCRYPTION_KEY=lsnh&^%$@!*1234567890abcdefghijk
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# --- Database (Postgres) ---
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=Timon1304!---

# --- Optional: Basic Auth for the editor (enterprise-y) ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=timothy
N8N_BASIC_AUTH_PASSWORD=Timon1304!---

# --- Optional: Public URL (only needed if doing OAuth/webhooks via ngrok/public domain) ---
# Uncomment + set when you have an HTTPS URL
# N8N_HOST=your-public-host
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://your-public-host
